# ── DART OpenAPI ──────────────────────────────────────────
# 인증키 신청: https://opendart.fss.or.kr/uss/umt/EgovMberInsertView.do
DART_API_KEY=your_40_char_dart_api_key_here

# ── Claude Code 구독 (선택) ───────────────────────────────
# 호스트에 `claude login` 이 되어 있으면 비워둬도 됨.
# 서버/CI 환경에서는 `claude setup-token` 으로 발급한 토큰을 입력.
CLAUDE_CODE_OAUTH_TOKEN=

# ── 서버 설정 ─────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=http://localhost:5555
DB_PATH=data/trades.db
